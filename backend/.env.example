# ─── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/globex_ai
# If using Supabase Connection Pooler (port 6543), set DIRECT_URL to the direct DB URL (port 5432) for migrations.
# DIRECT_URL=

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=debug

# ─── Future AI Agent Keys (plug in when ready) ───────────
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
N8N_WEBHOOK_URL=

# ─── Google Gemini AI Agent Config ───────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash-preview-05-20
AGENT_SERVICE_URL=http://localhost:8000/api/v1

# ─── ChromaDB (Vector Database for RAG) ─────────────────
CHROMA_HOST=http://localhost:8001
CHROMA_COLLECTION=globex_docs

# ─── Featherless / LLM Config ───────────────────────────
# Featherless.ai API key (get one at https://featherless.ai)
FEATHERLESS_API_KEY=
# Model identifier — must match Featherless catalog exactly.
# Priority order (best reasoning for GlobeX trade agent):
#   1st: Qwen/Qwen3-32B           (32B, hybrid thinking, best for complex reasoning)
#   2nd: deepseek-ai/DeepSeek-V3-0324  (131K ctx, strong reasoning)
#   3rd: meta-llama/Llama-3.3-70B-Instruct  (70B, reliable fallback)
LLM_MODEL=Qwen/Qwen3-32B
