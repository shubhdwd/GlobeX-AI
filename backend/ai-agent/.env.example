# ─── Google Gemini ────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./database/chroma_db
CHROMA_COLLECTION_NAME=globex_trade_knowledge

# ─── FastAPI ──────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── Memory / SQLite ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./database/globex_memory.db

# ─── RAG ──────────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_K=5

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
